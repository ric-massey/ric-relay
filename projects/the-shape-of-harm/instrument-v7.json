      "psychometric_reflective_scale",
      "context_free_drug_badness_measure",
      "individual_clinical_prediction_tool"
    ]
  },
  "views": [
    {
      "id": "one_episode",
      "denominator": "100000 defined episodes",
      "default_aggregate": false
    },
    {
      "id": "regular_use",
      "denominator": "1000 user-years or outcome-specific conditional denominator",
      "default_aggregate": false
    },
    {
      "id": "population_burden",
      "denominator": "100000 residents per year and total burden",
      "default_aggregate": false
    }
  ],
  "required_scenario_fields": [
    "substance",
