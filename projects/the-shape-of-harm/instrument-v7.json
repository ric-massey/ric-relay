    "geography",
    "calendar_period",
    "comparator",
    "outcome_window"
  ],
  "analysis_principles": [
    "natural_units_before_0_to_100_transformation",
    "non_overlapping_outcomes",
    "missing_is_not_zero",
    "direct_estimates_distinguished_from_model_predictions",
    "evidence_estimates_separate_from_value_weights",
    "swing_weights_only_after_value_functions_and_scale_anchors",
    "parameter_heterogeneity_bias_indirectness_and_structural_uncertainty_explicit",
    "no_universal_overall_rank_by_default"
  ],
  "validation_targets": [
    "content_validity",
    "review_process_reliability",
    "construct_behavior_hypotheses",
    "external_holdout_validation",
    "uncertainty_calibration",
    "temporal_and_geographic_transportability",
    "decision_robustness",
    "independent_replication"
  ],
  "prohibited_shortcuts": [
    "single_author_unblinded_scoring_as_primary_evidence",
    "cronbach_alpha_as_validation_of_distinct_harm_domains",
    "fixed_uncertainty_width_by_evidence_grade",
    "mixing_per_user_and_population_burden_in_one_axis",
    "combining_use_disorder_physical_dependence_and_withdrawal_as_one_construct",
    "publishing_rank_before_estimand_and_denominator_are_locked"
  ],
